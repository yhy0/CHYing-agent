# ============================================
# CHYing Agent 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 模型轮换：每 多少次 工具调用切换一次（subagent 中调用的不算，所以这里定义的很少），尝试突破模型的思维局限，提升解题能力
MAX_TURNS=40

SUBAGENT_MAX_TOOL_USES=20

# ============================================
# 7. 本地 CLI 配置（可选）
# ============================================
# 指定自定义 Claude Code CLI 路径（如企业内部 CLI）
# CLAUDE_CLI_PATH=/home/ubuntu/sec-claude/dist/sec-claude
CLAUDE_CLI_PATH=/Users/yhy/Documents/Github/sec-claude/dist/sec-claude
#
# CLI 模型路由开关（默认 true）
# true  = CLI 自行管理认证和模型路由，LLM_API_KEY / LLM_BASE_URL / LLM_MODEL 自动失效
# false = 仅使用 CLI 二进制，模型路由仍走 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL 配置
CLI_MODEL_ROUTING=false

# ============================================
# 1. LLM API 配置（必需）
# ============================================

# # ============================================
# # 1.1 备选 LLM 配置（可选，双模型交替运行）
# # ============================================
# # 配置后，Guidance Loop 每轮自动在主模型和备选模型之间切换，
# # 两个不同模型交替推理，突破单一模型的知识和思维局限。
# # 不配置则始终使用主模型。

LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/coding/anthropic
# # API 密钥
LLM_API_KEY=sk-sp-xxxx
# # 模型名称
LLM_MODEL=glm-5

# LLM_BASE_URL_ALT=https://api.minimaxi.com/anthropic
# LLM_API_KEY_ALT=sk-cp-xxxxx
# LLM_MODEL_ALT=MiniMax-M2.7


# 启用 C2 后渗透 Agent（默认关闭）                                                                       
# 关闭时 c2 prompt/工具完全不加载，不占用上下文                                                                 
# 需要后渗透能力时（如比赛第三赛程）设为 true 开启                                                              
ENABLE_C2_AGENT=false

# ============================================
# 2. Docker 配置（必需）
# ============================================
# Kali Docker 容器名称（用于执行渗透测试命令）
DOCKER_CONTAINER_NAME=chying-agent-docker

# ============================================
# 3. 运行时配置
# ============================================
# 最大重试次数（单题失败后的重试次数，默认 0 不重试）
MAX_RETRIES=0

# 单题超时时间（秒，默认 1200 = 20分钟）
SINGLE_TASK_TIMEOUT=2400

# 子 agent maxTurns（API 轮次上限，每轮可并发多个工具调用）
# executor: 短任务（nuclei扫描、curl探测、PoC执行），默认 10
EXECUTOR_SUBAGENT_MAX_TURNS=10
# browser: 浏览器操作（导航、截图、cookie提取），默认 10
BROWSER_SUBAGENT_MAX_TURNS=10
# reverse: 逆向分析（反编译、函数搜索、引用追踪），默认 15
REVERSE_SUBAGENT_MAX_TURNS=15
# c2: 后渗透（msf利用、提权、横向移动），默认 20
C2_SUBAGENT_MAX_TURNS=20

# Claude Code CLI 上下文压缩配置
# AUTO_COMPACT_WINDOW: CLI 将此值作为模型上下文窗口大小（tokens），
#   用于计算何时自动触发 compact。第三方模型虽宣称大窗口，但有效注意力远低于此。
#   建议设为宣称值的 40-50%：
#     kimi-k2.5 (宣称 256K) → 建议 100000-128000
#     MiniMax-M2.7 (宣称 200K) → 建议 80000-100000
#     GLM-5 (宣称 202K) → 建议 80000-100000
# AUTOCOMPACT_PCT_OVERRIDE: 上下文使用达到窗口的 N% 时触发 compact（CLI 默认约 93%）
#   设为 60 表示使用 60% 即触发，对弱模型推荐 50-70
CLAUDE_CODE_AUTO_COMPACT_WINDOW=200000
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=80

# 解题成功后自动生成 writeup 报告（默认开启，比赛场景建议关闭省时）
ENABLE_WRITEUP=0

# ============================================
# 4. 响应语言配置（可选）
# ============================================
# LLM 响应语言
# 默认不设置，使用英文 prompt（推荐，技术术语更准确，token 更省）
# 可选值：zh-CN（简体中文）、zh-TW（繁体中文）、en（英文）、ja（日文）等
# RESPONSE_LANGUAGE=zh-CN

# ============================================
# 5. MCP 服务器配置（可选）
# ============================================
# MCP 配置文件路径（默认使用项目根目录的 mcp.json）
# MCP_CONFIG_PATH=/path/to/mcp.json
# Ghidra MCP Server SSE 地址（由 ReverseAgent 独立加载，不在 .mcp.json 中配置）
GHIDRA_MCP_URL=http://127.0.0.1:8766/sse

# ============================================
# 6. Langfuse 监控（可选）
# ============================================
# 如需启用执行过程可视化监控，配置以下变量
# LANGFUSE_SECRET_KEY = "your_langfuse_secret_key_here"
# LANGFUSE_PUBLIC_KEY = "your_langfuse_public_key_here"
# LANGFUSE_BASE_URL = "https://us.cloud.langfuse.com"

# ============================================
# 7. 调试配置（可选）
# ============================================
# 数据库 SQL 日志输出（调试用）
DB_ECHO=false

# DOCKER_PASSTHROUGH_ENV=GH_TOKEN
# GH_TOKEN=your_github_token_here

# 腾讯云黑客松 api 配置
SERVER_HOST=http://10.0.0.44:8000
AGENT_TOKEN=your_agent_token_here

# COMPETITION_BASE_URL=http://43.134.110.135:8000
# COMPETITION_API_TOKEN=dummy